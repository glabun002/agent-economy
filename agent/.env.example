# Crossmint STAGING server API key — create at https://staging.crossmint.com
# Scopes: wallets.create, wallets.read, wallets:transactions.create,
#         wallets:transactions.sign, wallets:balance.read
CROSSMINT_API_KEY=

# Auto-generated by `npm run setup` (64-char hex master secret; testnet only)
CROSSMINT_SIGNER_SECRET=

# Auto-filled by `npm run setup`
CROSSMINT_WALLET_ADDRESS=

SERVER_URL=http://localhost:4021
